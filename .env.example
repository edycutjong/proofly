# ── Terminal 3 Dev Sandbox ─────────────────────────
# Agent's private key. The agent authenticates to T3N by signing the handshake
# challenge via the EthSign handler (there is no bearer-token auth). Leave unset
# to run in demo mode (mocked/sandbox transport, EthSign challenge not signed).
AGENT_KEY=0x...

# Optional overrides
# T3N_BASE_URL=https://api.terminal3.io
# PROOFLY_TENANT_SCRIPT=z:<tid>:proofly/contracts
# PROOFLY_SCRIPT_VERSION=1.0.0

# ── Board → Agent wiring (board service only) ──────
# Where the board's /api/* proxy routes reach the agent service.
# Local: http://localhost:3001 (default). Railway: set to the agent's URL,
# e.g. https://${{agent.RAILWAY_PUBLIC_DOMAIN}} (see docs/DEPLOY_RAILWAY.md).
AGENT_SERVICE_URL=http://localhost:3001

# ── Server Config ──────────────────────────────────
PORT=3000
NODE_ENV=development
