{
  "name": "proofly-agent",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run src",
    "test:coverage": "vitest run src --coverage --silent",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm run test:coverage"
  },
  "dependencies": {
    "@terminal3/t3n-sdk": "^3.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.2",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "ws": "^8.21.0"
  }
}
